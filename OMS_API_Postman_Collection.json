		{
			"name": "🏥 Health",
			"item": [
				{
					"name": "System Health Check",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    if (response.status === 'ok') {",
									"        pm.test('✅ Server is running', true);",
									"        pm.test('📅 Timestamp is present', response.timestamp !== undefined);",
									"    } else {",
									"        pm.test('❌ Server status not ok', false);",
									"    }",
									"} else {",
									"    pm.test('❌ Health check failed', false);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						}
					},
					"response": []
				}
			]
		}
