							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"order_id\": \"{{orderId}}\",\n  \"user_id\": \"{{userId}}\",\n  \"razorpay_order_id\": \"order_1234567890\",\n  \"amount\": 1999.98,\n  \"status\": \"CREATED\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/payments",
							"host": ["{{baseUrl}}"],
							"path": ["payments"]
						}
					},
					"response": []
				},
				{
					"name": "Razorpay Webhook",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "x-razorpay-signature",
								"value": "razorpay-signature-here"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"event\": \"payment.captured\",\n  \"payload\": {\n    \"payment\": {\n      \"entity\": {\n        \"id\": \"pay_1234567890\",\n        \"order_id\": \"{{orderId}}\",\n        \"amount\": 199998,\n        \"currency\": \"INR\",\n        \"status\": \"captured\"\n      }\n    }\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/payments/webhook",
							"host": ["{{baseUrl}}"],
							"path": ["payments", "webhook"]
						}
