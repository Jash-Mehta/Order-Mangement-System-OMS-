								"value": "Bearer {{jwtToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"order_id\": \"{{orderId}}\",\n  \"items\": [\n    {\n      \"product_id\": \"{{productId}}\",\n      \"quantity\": 2\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/reservation/order",
							"host": ["{{baseUrl}}"],
