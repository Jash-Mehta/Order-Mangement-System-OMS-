						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"product_id\": \"{{productId}}\",\n  \"order_id\": \"{{orderId}}\",\n  \"quantity\": 2,\n  \"expires_at\": \"2024-12-31T23:59:59.000Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/reservation",
							"host": ["{{baseUrl}}"],
							"path": ["inventory", "reservation"]
